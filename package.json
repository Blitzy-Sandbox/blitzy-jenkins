{
  "name": "jenkins-ui",
  "version": "1.0.0",
  "description": "Jenkins User Interface",
  "license": "MIT",
  "author": {
    "name": "Tom Fennelly",
    "email": "tom.fennelly@gmail.com",
    "url": "https://github.com/tfennelly"
  },
  "private": true,
  "scripts": {
    "dev": "vite",
    "prod": "vite build",
    "build": "yarn prod",
    "start": "vite --open",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "lint:js": "tsc --noEmit && eslint . && prettier --check .",
    "lint:js-ci": "eslint . -f checkstyle -o target/eslint-warnings.xml",
    "lint:css": "stylelint src/main/scss",
    "lint:css-ci": "stylelint src/main/scss --custom-formatter stylelint-checkstyle-reporter -o target/stylelint-warnings.xml",
    "lint:ci": "yarn lint:js-ci && yarn lint:css-ci",
    "lint:fix": "eslint --fix . && prettier --write . && stylelint src/main/scss --fix",
    "lint": "yarn lint:js && yarn lint:css"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.52.0",
    "@tanstack/react-query-devtools": "5.91.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@types/jquery": "^3.5.33",
    "@types/node": "^25.3.0",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@typescript-eslint/eslint-plugin": "8.56.0",
    "@typescript-eslint/parser": "8.56.0",
    "@vitejs/plugin-react": "4.6.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-checkstyle": "9.0.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.0",
    "globals": "17.3.0",
    "jsdom": "26.1.0",
    "postcss": "8.5.6",
    "postcss-preset-env": "11.1.2",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "stylelint": "17.1.0",
    "stylelint-checkstyle-reporter": "1.1.1",
    "stylelint-config-standard-scss": "17.0.0",
    "typescript": "5.8.3",
    "vite": "7.3.1",
    "vitest": "3.2.3"
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.21",
    "jquery": "3.7.1",
    "lodash": "4.17.23",
    "react": "19.2.1",
    "react-dom": "19.2.1"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
